<keymap version="1" name="XWin copy" parent="Default for XWin">
    <action id="$Paste">
        <keyboard-shortcut first-keystroke="ctrl v" />
        <keyboard-shortcut first-keystroke="shift insert" />
        <keyboard-shortcut first-keystroke="shift ctrl v" />
    </action>
    <action id="CollapseExpandableComponent">
        <keyboard-shortcut first-keystroke="ctrl subtract" />
        <keyboard-shortcut first-keystroke="ctrl minus" />
    </action>
    <action id="Editor Paste">
        <keyboard-shortcut first-keystroke="shift ctrl v" />
    </action>
    <action id="EditorChooseLookupItem">
        <keyboard-shortcut first-keystroke="enter" />
        <keyboard-shortcut first-keystroke="ctrl enter" />
    </action>
    <action id="EditorChooseLookupItemCompleteStatement" />
    <action id="EditorDown">
        <keyboard-shortcut first-keystroke="down" />
        <keyboard-shortcut first-keystroke="ctrl n" />
    </action>
    <action id="EditorEnter">
        <keyboard-shortcut first-keystroke="enter" />
        <keyboard-shortcut first-keystroke="shift enter" />
        <keyboard-shortcut first-keystroke="ctrl enter" />
    </action>
    <action id="EditorPaste">
        <keyboard-shortcut first-keystroke="shift insert" />
    </action>
    <action id="EditorSplitLine" />
    <action id="EditorStartNewLine" />
    <action id="EditorUp">
        <keyboard-shortcut first-keystroke="up" />
        <keyboard-shortcut first-keystroke="ctrl p" />
    </action>
    <action id="ExpandExpandableComponent">
        <keyboard-shortcut first-keystroke="ctrl add" />
        <keyboard-shortcut first-keystroke="ctrl equals" />
    </action>
    <action id="JupyterNotebookPasteCellAboveCommandModeAction">
        <keyboard-shortcut first-keystroke="shift v" />
    </action>
    <action id="NotebookRunCellSelectBelowAction" />
    <action id="OpenInRightSplit">
        <mouse-shortcut keystroke="alt button1 doubleClick" />
    </action>
    <action id="PasteMultiple">
        <keyboard-shortcut first-keystroke="shift ctrl insert" />
    </action>
    <action id="Terminal.Paste">
        <keyboard-shortcut first-keystroke="ctrl v" />
        <keyboard-shortcut first-keystroke="shift insert" />
    </action>
</keymap>
