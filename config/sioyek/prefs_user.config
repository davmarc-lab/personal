# Increase the margin/space between pages (in pixels)
page_separator_width 20

# Change the background color (the space around the PDF)
# Format is R G B (0 to 1, where 0 is black, 1 is white)
background_color 0.15 0.15 0.15

# Optional: To ensure the page itself has a distinct color from the background
# This makes the "page" look like a sheet of paper on the background
custom_background_color 0.9 0.9 0.9
